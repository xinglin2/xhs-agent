# Copy this file to .env and fill in all values before running.

# PostgreSQL
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/xhs_agent

# Redis (BullMQ)
REDIS_URL=redis://localhost:6379/0

# AES-256-GCM key — generate with: python -c "import os,binascii; print(binascii.hexlify(os.urandom(32)).decode())"
AES_KEY=changeme_64_hex_chars_here_0000000000000000000000000000000000000000

# Cloudflare R2
R2_ACCOUNT_ID=your_account_id
R2_ACCESS_KEY_ID=your_access_key_id
R2_SECRET_ACCESS_KEY=your_secret_access_key
R2_BUCKET_NAME=xhs-agent-media
R2_PUBLIC_URL=https://pub-CHANGEME.r2.dev

# App tunables
LOG_LEVEL=INFO
HEADLESS=true
PUBLISHER_QUEUE_NAME=xhs-publish
MAX_CONCURRENT_JOBS=2
UI_DELAY_MS=800

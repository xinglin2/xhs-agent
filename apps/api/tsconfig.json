{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "lib": ["ES2022"],
    "outDir": "./dist",
    "strict": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "declaration": true,
    "sourceMap": true,
    "paths": {
      "@xhs/shared": ["../../packages/shared/src/index.ts"],
      "@xhs/db": ["../../packages/db/src/index.ts"],
      "@xhs/logger": ["../../packages/logger/src/index.ts"]
    }
  },
  "include": [
    "src/**/*",
    "../../packages/shared/src/**/*",
    "../../packages/db/src/**/*",
    "../../packages/logger/src/**/*"
  ],
  "exclude": ["node_modules", "dist"]
}
